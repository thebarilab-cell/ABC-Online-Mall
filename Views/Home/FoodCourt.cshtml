@model List<ABCRMALLWebsite.Models.FoodCourt>
@{
    ViewData["Title"] = "Food Court ABC Mall - Premier Shopping Destination";
}

<!-- Hero Section -->
<section class="hero-section text-white py-5 mt-5" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-8" data-aos="fade-right">
                <h1 class="display-3 fw-bold mb-4">🍔 Food Court</h1>
                <p class="lead mb-4">Embark on a culinary journey with global cuisines, local delights, and everything in between. Your taste adventure starts here!</p>
                <div class="search-box">
                    <div class="input-group input-group-lg">
                        <input type="text" class="form-control" placeholder="Search cuisine, restaurants...">
                        <button class="btn btn-light" type="button">
                            <i class="fas fa-search"></i>
                        </button>
                    </div>
                </div>
            </div>
            <div class="col-lg-4" data-aos="fade-left">
                <div class="text-center">
                    <div class="floating-card glass-effect p-4 rounded-3">
                        <i class="fas fa-utensils fa-6x text-white mb-3"></i>
                        <h4 class="text-white">Global Cuisines</h4>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Cuisine Categories -->
<section class="py-4 bg-light">
    <div class="container">
        <div class="row">
            <div class="col-12">
                <div class="d-flex flex-wrap justify-content-center gap-3">
                    <button class="btn btn-outline-danger active filter-btn" data-filter="all">All Cuisines</button>
                    <button class="btn btn-outline-danger filter-btn" data-filter="Fast Food">🍔 Fast Food</button>
                    <button class="btn btn-outline-danger filter-btn" data-filter="Chinese">🥡 Chinese</button>
                    <button class="btn btn-outline-danger filter-btn" data-filter="Italian">🍕 Italian</button>
                    <button class="btn btn-outline-danger filter-btn" data-filter="Indian">🍛 Indian</button>
                    <button class="btn btn-outline-danger filter-btn" data-filter="Desserts">🍰 Desserts</button>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Food Counters -->
<section class="py-5">
    <div class="container">
        <div class="row g-4" id="food-container">
            @foreach (var foodCourt in Model)
            {
                <div class="col-lg-4 col-md-6 mb-4 food-item" data-category="@foodCourt.CuisineType" data-aos="flip-left">
                    <div class="card floating-card hover-3d border-0 overflow-hidden h-100">
                        <div class="position-relative">
                            <img src="@(string.IsNullOrEmpty(foodCourt.ImagePath) ? "https://images.unsplash.com/photo-1414235077428-338989a2e8c0?ixlib=rb-4.0.3&auto=format&fit=crop&w=500&q=80" : foodCourt.ImagePath)"
                                 class="card-img-top" alt="@foodCourt.CounterName" style="height: 200px; object-fit: cover;">
                            <div class="position-absolute top-0 end-0 m-3">
                                <span class="badge bg-warning text-dark">@foodCourt.Floor</span>
                            </div>
                            <div class="position-absolute bottom-0 start-0 m-3">
                                <span class="badge bg-success">@foodCourt.PriceRange</span>
                            </div>
                        </div>
                        <div class="card-body d-flex flex-column">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h5 class="card-title fw-bold">@foodCourt.CounterName</h5>
                                <span class="badge bg-danger">@foodCourt.CuisineType</span>
                            </div>

                            <div class="menu-preview mb-3">
                                <h6 class="text-muted">Popular Items:</h6>
                                <p class="small text-dark">@foodCourt.MenuItems</p>
                            </div>

                            <div class="rating mb-3">
                                <div class="stars">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <i class="fas fa-star @(i <= 4 ? "text-warning" : "text-muted")"></i>
                                    }
                                </div>
                                <small class="text-muted">(4.2/5)</small>
                            </div>

                            <div class="mt-auto">
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="text-success fw-bold">@foodCourt.PriceRange</span>
                                    <button class="btn btn-outline-danger btn-sm">
                                        <i class="fas fa-utensils me-1"></i>Order Now
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }

            @if (!Model.Any())
            {
                <div class="col-12 text-center py-5" data-aos="fade-up">
                    <div class="empty-state">
                        <i class="fas fa-utensils fa-4x text-muted mb-3"></i>
                        <h3 class="text-muted">Food Court Coming Soon!</h3>
                        <p class="text-muted">We're preparing delicious surprises for you!</p>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- Special Offers -->
<section class="py-5 bg-dark text-white">
    <div class="container">
        <div class="text-center mb-5" data-aos="fade-up">
            <h2 class="display-4 fw-bold gradient-text">🎉 Special Offers</h2>
            <p class="lead">Don't miss out on these amazing deals!</p>
        </div>

        <div class="row g-4">
            <div class="col-md-4" data-aos="zoom-in">
                <div class="card floating-card bg-warning text-dark border-0 overflow-hidden">
                    <div class="card-body text-center p-4">
                        <i class="fas fa-pizza-slice fa-3x mb-3"></i>
                        <h4>Buy 1 Get 1 Free</h4>
                        <p>On all pizzas every Monday</p>
                        <small class="text-muted">Valid until December 2024</small>
                    </div>
                </div>
            </div>
            <div class="col-md-4" data-aos="zoom-in" data-aos-delay="100">
                <div class="card floating-card bg-success text-white border-0 overflow-hidden">
                    <div class="card-body text-center p-4">
                        <i class="fas fa-coffee fa-3x mb-3"></i>
                        <h4>20% Off</h4>
                        <p>On beverages with any meal</p>
                        <small class="text-light">Weekend special</small>
                    </div>
                </div>
            </div>
            <div class="col-md-4" data-aos="zoom-in" data-aos-delay="200">
                <div class="card floating-card bg-primary text-white border-0 overflow-hidden">
                    <div class="card-body text-center p-4">
                        <i class="fas fa-birthday-cake fa-3x mb-3"></i>
                        <h4>Free Dessert</h4>
                        <p>On your birthday</p>
                        <small class="text-light">Show your ID</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        // Filter functionality
        document.querySelectorAll('.filter-btn').forEach(button => {
            button.addEventListener('click', function() {
                document.querySelectorAll('.filter-btn').forEach(btn => btn.classList.remove('active'));
                this.classList.add('active');

                const filter = this.getAttribute('data-filter');
                const items = document.querySelectorAll('.food-item');

                items.forEach(item => {
                    if (filter === 'all' || item.getAttribute('data-category') === filter) {
                        item.style.display = 'block';
                        setTimeout(() => {
                            item.style.opacity = '1';
                            item.style.transform = 'scale(1)';
                        }, 50);
                    } else {
                        item.style.opacity = '0';
                        item.style.transform = 'scale(0.8)';
                        setTimeout(() => {
                            item.style.display = 'none';
                        }, 300);
                    }
                });
            });
        });

        // Add floating animation to cards
        gsap.to('.floating-card', {
            y: -10,
            duration: 2,
            repeat: -1,
            yoyo: true,
            ease: "power1.inOut"
        });
    </script>
}