@model List<ABCRMALLWebsite.Models.Gallery>
@{
    ViewData["Title"] = "Manage Gallery";
}
<div>
    <br>
</div>
<div>
    <br>
</div>
<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Manage Gallery Images</h2>
        <div>
            <a href="@Url.Action("Dashboard")" class="btn btn-secondary">Back to Dashboard</a>
            <a href="@Url.Action("AddGalleryImage")" class="btn btn-success">Add New Image</a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }

    <div class="row">
        @foreach (var image in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card shadow">
                    <img src="@(string.IsNullOrEmpty(image.ImagePath) ? "https://via.placeholder.com/300x200/6c757d/ffffff?text=No+Image" : image.ImagePath)"
                         class="card-img-top" alt="@image.Title" style="height: 200px; object-fit: cover;">
                    <div class="card-body">
                        <h5 class="card-title">@image.Title</h5>
                        <p class="card-text">@image.Description</p>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="badge bg-primary">@image.Category</span>
                            <small class="text-muted">@image.UploadDate.ToString("MMM dd, yyyy")</small>
                        </div>
                        <div class="mt-3">
                            <a href="@Url.Action("EditGalleryImage", new { id = image.Id })"
                               class="btn btn-warning btn-sm">Edit</a>
                            <a href="@Url.Action("DeleteGalleryImage", new { id = image.Id })"
                               class="btn btn-danger btn-sm"
                               onclick="return confirm('Are you sure you want to delete this image?')">Delete</a>
                        </div>
                    </div>
                </div>
            </div>
        }

        @if (!Model.Any())
        {
            <div class="col-12">
                <div class="text-center text-muted py-5">
                    <h5>No gallery images found</h5>
                    <p>Add your first image to the gallery!</p>
                    <a href="@Url.Action("AddGalleryImage")" class="btn btn-primary">Add First Image</a>
                </div>
            </div>
        }
    </div>
</div>