@model ABCRMALLWebsite.Models.Movie
@{
    ViewData["Title"] = "Edit Movie - Admin";
}

<style>
    .page-title {
        color: #2c3e50;
        font-weight: 600;
        border-bottom: 3px solid #dc3545;
        padding-bottom: 10px;
    }

    .admin-badge {
        background: linear-gradient(45deg, #dc3545, #e74c3c);
        color: white;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.8rem;
        font-weight: 600;
        margin-left: 10px;
    }

    .movie-edit-card {
        border-radius: 12px;
        overflow: hidden;
        border: 2px solid #f8f9fa;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .movie-edit-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
        }

    .card-header {
        border-radius: 0 !important;
        font-weight: 600;
        background: linear-gradient(135deg, #dc3545, #c82333) !important;
    }

    .form-label {
        color: #2c3e50;
        margin-bottom: 8px;
        font-weight: 600;
    }

    .form-control {
        border-radius: 8px;
        border: 1px solid #ddd;
        padding: 12px 15px;
        transition: all 0.3s;
    }

        .form-control:focus {
            border-color: #dc3545;
            box-shadow: 0 0 0 0.2rem rgba(220, 53, 69, 0.25);
        }

    .input-group-text {
        background-color: #f8f9fa;
        border: 1px solid #ddd;
        border-right: none;
    }

    .btn {
        border-radius: 8px;
        font-weight: 500;
        transition: all 0.3s;
    }

    .btn-success {
        background: linear-gradient(135deg, #28a745, #20c997);
        border: none;
    }

        .btn-success:hover {
            background: linear-gradient(135deg, #218838, #1e9e8a);
            transform: translateY(-2px);
        }

    .btn-danger {
        background: linear-gradient(135deg, #dc3545, #c82333);
        border: none;
    }

        .btn-danger:hover {
            background: linear-gradient(135deg, #c82333, #a71e2a);
            transform: translateY(-2px);
        }

    .btn-outline-secondary:hover {
        transform: translateY(-2px);
    }

    .form-text {
        font-size: 0.85rem;
        color: #6c757d;
        margin-top: 5px;
    }

    .alert {
        border-radius: 10px;
        border: none;
    }

    .text-danger {
        font-size: 0.875rem;
    }

    .poster-preview {
        max-width: 200px;
        max-height: 300px;
        border-radius: 8px;
        box-shadow: 0 4px 8px rgba(0,0,0,0.1);
        margin-top: 10px;
        display: none;
    }

    .preview-container {
        text-align: center;
        margin-top: 15px;
    }

    .preview-label {
        font-size: 0.9rem;
        color: #6c757d;
        margin-bottom: 5px;
    }

    .admin-actions {
        background: #f8f9fa;
        border-radius: 8px;
        padding: 15px;
        margin-top: 20px;
    }

    .action-title {
        color: #dc3545;
        font-weight: 600;
        margin-bottom: 10px;
    }

    .required-field::after {
        content: " *";
        color: #dc3545;
    }

    @@media (max-width: 768px) {
        .d-flex.justify-content-between {
            flex-direction: column;
            align-items: flex-start;
        }

            .d-flex.justify-content-between > div:last-child {
                margin-top: 15px;
            }

        .d-flex.justify-content-end {
            flex-direction: column;
            gap: 10px;
        }

            .d-flex.justify-content-end .btn {
                width: 100%;
            }

        .poster-preview {
            max-width: 150px;
            max-height: 225px;
        }
    }
</style>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="page-title">
            Edit Movie
            <span class="admin-badge">ADMIN</span>
        </h2>
        <div>
            <a href="@Url.Action("ManageMovies")" class="btn btn-secondary">
                <i class="fas fa-arrow-left me-2"></i>Back to Manage Movies
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-circle me-2"></i>@TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row justify-content-center">
        <div class="col-lg-10 col-xl-8">
            <div class="card shadow-lg border-0 movie-edit-card">
                <div class="card-header bg-primary text-white py-3">
                    <h4 class="mb-0"><i class="fas fa-edit me-2"></i>Edit Movie Information</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="EditMovie" method="post" class="needs-validation" novalidate>
                        <input type="hidden" asp-for="Id" />

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <div class="form-group">
                                    <label asp-for="Title" class="form-label required-field">Movie Title</label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="fas fa-heading"></i></span>
                                        <input asp-for="Title" class="form-control" placeholder="Enter movie title" required />
                                    </div>
                                    <span asp-validation-for="Title" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="col-md-6 mb-3">
                                <div class="form-group">
                                    <label asp-for="Genre" class="form-label">Genre</label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="fas fa-tags"></i></span>
                                        <input asp-for="Genre" class="form-control" placeholder="Enter genre" />
                                    </div>
                                    <span asp-validation-for="Genre" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <div class="form-group">
                                    <label asp-for="Duration" class="form-label">Duration</label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="fas fa-clock"></i></span>
                                        <input asp-for="Duration" class="form-control" placeholder="e.g. 2h 30m" />
                                    </div>
                                    <span asp-validation-for="Duration" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="col-md-6 mb-3">
                                <div class="form-group">
                                    <label asp-for="TicketPrice" class="form-label required-field">Ticket Price (₹)</label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="fas fa-rupee-sign"></i></span>
                                        <input asp-for="TicketPrice" type="number" step="1" class="form-control" placeholder="Enter ticket price" required min="100" max="5000" />
                                    </div>
                                    <span asp-validation-for="TicketPrice" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <!-- Movie Poster URL Field -->
                        <div class="mb-3">
                            <div class="form-group">
                                <label asp-for="PosterUrl" class="form-label">Movie Poster URL</label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="fas fa-image"></i></span>
                                    <input asp-for="PosterUrl" type="url" class="form-control" placeholder="https://example.com/poster.jpg" />
                                </div>
                                <div class="form-text">Enter the URL of the movie poster image (optional)</div>
                                <span asp-validation-for="PosterUrl" class="text-danger small"></span>

                                <!-- Poster Preview -->
                                <div class="preview-container">
                                    <div class="preview-label">Poster Preview:</div>
                                    <img id="posterPreview" class="poster-preview" alt="Movie poster preview"
                                         onerror="this.style.display='none'" />
                                </div>
                            </div>
                        </div>

                        <!-- Existing ImagePath Field -->
                        <div class="mb-3">
                            <div class="form-group">
                                <label asp-for="ImagePath" class="form-label">Existing Image Path</label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="fas fa-folder"></i></span>
                                    <input asp-for="ImagePath" class="form-control" placeholder="/images/movies/movie.jpg" />
                                </div>
                                <div class="form-text">Current image file path</div>
                                <span asp-validation-for="ImagePath" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <div class="form-group">
                                    <label asp-for="TotalSeats" class="form-label required-field">Total Seats</label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="fas fa-users"></i></span>
                                        <input asp-for="TotalSeats" type="number" class="form-control" placeholder="Enter total seats" required min="1" max="500" />
                                    </div>
                                    <span asp-validation-for="TotalSeats" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="col-md-6 mb-3">
                                <div class="form-group">
                                    <label asp-for="AvailableSeats" class="form-label required-field">Available Seats</label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="fas fa-chair"></i></span>
                                        <input asp-for="AvailableSeats" type="number" class="form-control" placeholder="Enter available seats" required min="0" max="500" />
                                    </div>
                                    <span asp-validation-for="AvailableSeats" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <div class="mb-4">
                            <div class="form-group">
                                <label asp-for="ShowTimings" class="form-label">Show Timings</label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="fas fa-calendar-alt"></i></span>
                                    <input asp-for="ShowTimings" class="form-control" placeholder="e.g. 10:00 AM, 1:00 PM, 4:30 PM" />
                                </div>
                                <div class="form-text">Enter multiple show times separated by commas</div>
                                <span asp-validation-for="ShowTimings" class="text-danger small"></span>
                            </div>
                        </div>

                        <!-- Admin Actions Section -->
                        <div class="admin-actions">
                            <h6 class="action-title"><i class="fas fa-shield-alt me-2"></i>Admin Actions</h6>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" id="featuredMovie">
                                        <label class="form-check-label" for="featuredMovie">
                                            Feature this movie
                                        </label>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" id="nowShowing" checked>
                                        <label class="form-check-label" for="nowShowing">
                                            Now Showing
                                        </label>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between align-items-center pt-4 border-top">
                            <div>
                                <button type="button" class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#deleteModal">
                                    <i class="fas fa-trash me-2"></i>Delete Movie
                                </button>
                            </div>
                            <div class="d-flex">
                                <button type="submit" class="btn btn-success me-3 px-4 py-2">
                                    <i class="fas fa-save me-2"></i>Save Changes
                                </button>
                                <a href="@Url.Action("ManageMovies")" class="btn btn-outline-secondary px-4 py-2">
                                    <i class="fas fa-times me-2"></i>Cancel
                                </a>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title text-danger" id="deleteModalLabel">
                    <i class="fas fa-exclamation-triangle me-2"></i>Confirm Deletion
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete the movie <strong>"@Model.Title"</strong>?</p>
                <p class="text-danger"><small>This action cannot be undone. All showtimes and bookings for this movie will be removed.</small></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <form asp-action="DeleteMovie" method="post" style="display: inline;">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button type="submit" class="btn btn-danger">
                        <i class="fas fa-trash me-2"></i>Delete Movie
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Add Font Awesome if not already included
        if (!document.querySelector('link[href*="font-awesome"]')) {
            const faLink = document.createElement('link');
            faLink.rel = 'stylesheet';
            faLink.href = 'https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css';
            document.head.appendChild(faLink);
        }

        // Enhanced form validation
        (function () {
            'use strict';
            window.addEventListener('load', function () {
                var forms = document.getElementsByClassName('needs-validation');
                var validation = Array.prototype.filter.call(forms, function (form) {
                    form.addEventListener('submit', function (event) {
                        if (form.checkValidity() === false) {
                            event.preventDefault();
                            event.stopPropagation();

                            // Scroll to first error
                            var firstError = form.querySelector('.is-invalid');
                            if (firstError) {
                                firstError.scrollIntoView({ behavior: 'smooth', block: 'center' });
                            }
                        }
                        form.classList.add('was-validated');
                    }, false);
                });
            }, false);
        })();

        // Real-time validation for available seats vs total seats
        document.addEventListener('DOMContentLoaded', function() {
            const availableSeatsInput = document.querySelector('input[name="AvailableSeats"]');
            const totalSeatsInput = document.querySelector('input[name="TotalSeats"]');

            function validateSeats() {
                const available = parseInt(availableSeatsInput.value);
                const total = parseInt(totalSeatsInput.value);

                if (available > total) {
                    availableSeatsInput.setCustomValidity('Available seats cannot exceed total seats');
                } else {
                    availableSeatsInput.setCustomValidity('');
                }
            }

            if (availableSeatsInput && totalSeatsInput) {
                availableSeatsInput.addEventListener('input', validateSeats);
                totalSeatsInput.addEventListener('input', validateSeats);
            }

            // Poster URL preview functionality
            const posterUrlInput = document.querySelector('input[name="PosterUrl"]');
            const posterPreview = document.getElementById('posterPreview');

            function updatePosterPreview() {
                const url = posterUrlInput.value.trim();
                if (url) {
                    posterPreview.src = url;
                    posterPreview.style.display = 'block';

                    // Check if image loads successfully
                    posterPreview.onload = function() {
                        posterPreview.style.display = 'block';
                    };

                    posterPreview.onerror = function() {
                        posterPreview.style.display = 'none';
                    };
                } else {
                    posterPreview.style.display = 'none';
                }
            }

            if (posterUrlInput && posterPreview) {
                // Update preview when URL changes
                posterUrlInput.addEventListener('input', updatePosterPreview);

                // Update preview when page loads (in case there's already a value)
                updatePosterPreview();
            }
        });
    </script>
}