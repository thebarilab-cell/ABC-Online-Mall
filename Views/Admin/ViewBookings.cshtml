
@model List<ABCRMALLWebsite.Models.TicketBooking>
@{
    ViewData["Title"] = "View Bookings";
}
<div>
    <br>
</div>
<div>
    <br>
</div>
<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Ticket Bookings</h2>
        <a href="@Url.Action("Dashboard")" class="btn btn-secondary">Back to Dashboard</a>
    </div>

    <div class="card shadow">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>ID</th>
                            <th>Customer Name</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th>Movie</th>
                            <th>Tickets</th>
                            <th>Show Time</th>
                            <th>Total Amount</th>
                            <th>Booking Date</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var booking in Model)
                        {
                            <tr>
                                <td>@booking.Id</td>
                                <td>@booking.CustomerName</td>
                                <td>@booking.Email</td>
                                <td>@booking.Phone</td>
                                <td>@booking.Movie?.Title</td>
                                <td>@booking.NumberOfTickets</td>
                                <td>@booking.ShowTime.ToString("MMM dd, yyyy hh:mm tt")</td>
                                <td>@booking.TotalAmount</td>
                                <td>@booking.BookingDate.ToString("MMM dd, yyyy")</td>
                                <td>
                                    <span class="badge @(booking.BookingStatus == "Cancelled" ? "bg-danger" :
                                                                                                   booking.BookingStatus == "Pending" ? "bg-warning" : "bg-success")">
                                        @booking.BookingStatus
                                    </span>
                                </td>
                            </tr>
                        }

                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="12" class="text-center text-muted py-4">
                                    <h5>No bookings found</h5>
                                    <p>Customer bookings will appear here</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
