@model List<ABCRMALLWebsite.Models.Movie>
@{
    ViewData["Title"] = "Movies ABC Mall - Premier Shopping Destination";
}

<!-- Hero Section -->
<section class="hero-section text-white py-5 mt-5" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-8" data-aos="fade-right">
                <h1 class="display-3 fw-bold mb-4">🎬 Cinema Experience</h1>
                <p class="lead mb-4">Immerse yourself in blockbuster movies with state-of-the-art Dolby Atmos sound and premium recliner seating.</p>
                <div class="d-flex flex-wrap gap-3">
                    <a href="#now-showing" class="btn btn-light btn-lg px-4 py-2 pulse-animation">
                        <i class="fas fa-ticket-alt me-2"></i>Book Now
                    </a>
                    <a href="#facilities" class="btn btn-outline-light btn-lg px-4 py-2">
                        <i class="fas fa-star me-2"></i>Our Facilities
                    </a>
                </div>
            </div>
            <div class="col-lg-4" data-aos="fade-left">
                <div class="text-center">
                    <div class="floating-card glass-effect p-4 rounded-3">
                        <i class="fas fa-film fa-6x text-white mb-3"></i>
                        <h4 class="text-white">Premium Multiplex</h4>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Now Showing Section -->
<section id="now-showing" class="py-5 bg-dark text-white">
    <div class="container">
        <div class="text-center mb-5" data-aos="fade-up">
            <h2 class="display-4 fw-bold gradient-text">Now Showing</h2>
            <p class="lead">Book your tickets for the latest blockbusters</p>
        </div>

        <!-- Movie Category Filters -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="text-center">
                    <div class="btn-group btn-group-lg flex-wrap" role="group">
                        <button type="button" class="btn btn-outline-primary filter-btn active" data-filter="all">
                            <i class="fas fa-globe me-2"></i>All Movies
                        </button>
                        <button type="button" class="btn btn-outline-danger filter-btn" data-filter="hollywood">
                            <i class="fas fa-film me-2"></i>Hollywood
                        </button>
                        <button type="button" class="btn btn-outline-warning filter-btn" data-filter="bollywood">
                            <i class="fas fa-bolt me-2"></i>Bollywood
                        </button>
                        <button type="button" class="btn btn-outline-info filter-btn" data-filter="action">
                            <i class="fas fa-fire me-2"></i>Action
                        </button>
                        <button type="button" class="btn btn-outline-success filter-btn" data-filter="sci-fi">
                            <i class="fas fa-rocket me-2"></i>Sci-Fi
                        </button>
                        <button type="button" class="btn btn-outline-dark filter-btn" data-filter="18plus">
                            <i class="fas fa-ban me-2"></i>18+ Movies
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4" id="movies-container">
            @foreach (var movie in Model)
            {
                // Determine movie categories
                var isHollywood = movie.Genre?.ToLower().Contains("sci-fi") == true ||
                movie.Genre?.ToLower().Contains("adventure") == true ||
                movie.Title?.ToLower().Contains("avatar") == true ||
                movie.Title?.ToLower().Contains("john wick") == true ||
                movie.Title?.ToLower().Contains("spider-man") == true;

                var isBollywood = movie.Genre?.ToLower().Contains("drama") == true ||
                movie.Title?.ToLower().Contains("pathaan") == true ||
                movie.Title?.ToLower().Contains("jawan") == true ||
                movie.Title?.ToLower().Contains("animal") == true ||
                movie.Title?.ToLower().Contains("gadar") == true;

                var isAction = movie.Genre?.ToLower().Contains("action") == true;
                var isSciFi = movie.Genre?.ToLower().Contains("sci-fi") == true;
                var is18Plus = movie.Genre?.ToLower().Contains("thriller") == true ||
                movie.Title?.ToLower().Contains("animal") == true;

                var categories = new List<string> { "all" };
                if (isHollywood) categories.Add("hollywood");
                if (isBollywood) categories.Add("bollywood");
                if (isAction) categories.Add("action");
                if (isSciFi) categories.Add("sci-fi");
                if (is18Plus) categories.Add("18plus");

                var categoryClass = string.Join(" ", categories);

                <div class="col-lg-6 mb-4 movie-item @categoryClass" data-aos="flip-up" data-categories="@string.Join(",", categories)">
                    <div class="card floating-card hover-3d border-0 bg-dark text-white overflow-hidden">
                        <div class="row g-0">
                            <div class="col-md-4 position-relative">
                                <img src="@(string.IsNullOrEmpty(movie.ImagePath) ? "https://images.unsplash.com/photo-1489599809505-fb40ebc14d59?ixlib=rb-4.0.3&auto=format&fit=crop&w=500&q=80" : movie.PosterUrl)"
                                     class="img-fluid h-100" alt="@movie.Title" style="object-fit: cover;"
                                     onerror="this.src='https://images.unsplash.com/photo-1489599809505-fb40ebc14d59?ixlib=rb-4.0.3&auto=format&fit=crop&w=500&q=80'">
                                <div class="position-absolute top-0 start-0 m-2">
                                    @if (is18Plus)
                                    {
                                        <span class="badge bg-dark">18+</span>
                                    }
                                    else if (isBollywood)
                                    {
                                        <span class="badge bg-warning text-dark">Bollywood</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">New</span>
                                    }
                                </div>
                                <div class="position-absolute top-0 end-0 m-2">
                                    @if (isHollywood && !isBollywood)
                                    {
                                        <span class="badge bg-primary">Hollywood</span>
                                    }
                                </div>
                            </div>
                            <div class="col-md-8">
                                <div class="card-body d-flex flex-column h-100">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <h5 class="card-title fw-bold">@movie.Title</h5>
                                        <span class="badge bg-primary">@movie.Genre</span>
                                    </div>

                                    <div class="movie-info mb-3">
                                        <div class="d-flex gap-4 text-muted small">
                                            <span><i class="fas fa-clock me-1"></i> @movie.Duration</span>
                                            <span><i class="fas fa-tag me-1"></i> ₹@movie.TicketPrice</span>
                                        </div>
                                    </div>

                                    <div class="show-timings mb-3">
                                        <h6 class="text-warning">Show Timings:</h6>
                                        <div class="timing-badges">
                                            @foreach (var timing in movie.ShowTimings.Split(','))
                                            {
                                                <span class="badge bg-outline-light me-1 mb-1">@timing.Trim()</span>
                                            }
                                        </div>
                                    </div>

                                    <div class="seats-availability mb-3">
                                        <div class="progress" style="height: 8px;">
                                            @{
                                                var seatPercentage = (movie.AvailableSeats * 100) / movie.TotalSeats;
                                            }
                                            <div class="progress-bar @(seatPercentage > 50 ? "bg-success" : seatPercentage > 20 ? "bg-warning" : "bg-danger")"
                                                 style="width: @seatPercentage%"></div>
                                        </div>
                                        <small class="text-muted">@movie.AvailableSeats of @movie.TotalSeats seats available</small>
                                    </div>

                                    <div class="mt-auto">
                                        @if (movie.AvailableSeats > 0)
                                        {
                                            <a href="@Url.Action("BookTicket", "Booking", new { movieId = movie.Id })"
                                               class="btn btn-success w-100 pulse-animation">
                                                <i class="fas fa-ticket-alt me-2"></i>Book Tickets
                                            </a>
                                        }
                                        else
                                        {
                                            <button class="btn btn-secondary w-100" disabled>
                                                <i class="fas fa-times me-2"></i>House Full
                                            </button>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }

            @if (!Model.Any())
            {
                <div class="col-12 text-center py-5" data-aos="fade-up">
                    <div class="empty-state">
                        <i class="fas fa-film fa-4x text-muted mb-3"></i>
                        <h3 class="text-muted">No movies currently showing</h3>
                        <p class="text-muted">Check back soon for exciting new releases!</p>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- Facilities Section -->
<section id="facilities" class="py-5 bg-light">
    <div class="container">
        <div class="text-center mb-5" data-aos="fade-up">
            <h2 class="display-4 fw-bold gradient-text">Premium Theater Experience</h2>
            <p class="lead">State-of-the-art facilities for ultimate comfort</p>
        </div>

        <div class="row g-4 stagger-animation">
            <div class="col-lg-3 col-md-6 text-center stagger-item" data-aos="zoom-in">
                <div class="facility-card p-4">
                    <div class="icon-wrapper mb-3">
                        <i class="fas fa-couch fa-3x gradient-text"></i>
                    </div>
                    <h5>Recliner Seats</h5>
                    <p class="text-muted">Luxury recliners with ample legroom</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6 text-center stagger-item" data-aos="zoom-in" data-aos-delay="100">
                <div class="facility-card p-4">
                    <div class="icon-wrapper mb-3">
                        <i class="fas fa-volume-up fa-3x gradient-text"></i>
                    </div>
                    <h5>Dolby Atmos</h5>
                    <p class="text-muted">Immersive 360° sound experience</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6 text-center stagger-item" data-aos="zoom-in" data-aos-delay="200">
                <div class="facility-card p-4">
                    <div class="icon-wrapper mb-3">
                        <i class="fas fa-utensils fa-3x gradient-text"></i>
                    </div>
                    <h5>Food Service</h5>
                    <p class="text-muted">Fresh popcorn & beverage counters</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6 text-center stagger-item" data-aos="zoom-in" data-aos-delay="300">
                <div class="facility-card p-4">
                    <div class="icon-wrapper mb-3">
                        <i class="fas fa-parking fa-3x gradient-text"></i>
                    </div>
                    <h5>Free Parking</h5>
                    <p class="text-muted">Ample secure parking space</p>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        // Movie filtering functionality
        document.addEventListener('DOMContentLoaded', function() {
            const filterButtons = document.querySelectorAll('.filter-btn');
            const movieItems = document.querySelectorAll('.movie-item');

            filterButtons.forEach(button => {
                button.addEventListener('click', function() {
                    // Remove active class from all buttons
                    filterButtons.forEach(btn => btn.classList.remove('active'));
                    // Add active class to clicked button
                    this.classList.add('active');

                    const filter = this.getAttribute('data-filter');

                    movieItems.forEach(item => {
                        if (filter === 'all') {
                            item.style.display = 'block';
                        } else {
                            const categories = item.getAttribute('data-categories');
                            if (categories && categories.includes(filter)) {
                                item.style.display = 'block';
                            } else {
                                item.style.display = 'none';
                            }
                        }

                        // Add fade animation
                        setTimeout(() => {
                            item.style.opacity = item.style.display === 'block' ? '1' : '0';
                        }, 50);
                    });
                });
            });

            // Add interactive elements
            document.querySelectorAll('.timing-badges .badge').forEach(badge => {
                badge.addEventListener('click', function() {
                    document.querySelectorAll('.timing-badges .badge').forEach(b => b.classList.remove('bg-warning', 'text-dark'));
                    this.classList.add('bg-warning', 'text-dark');
                });
            });

            // Pulse animation for available movies
            document.querySelectorAll('.pulse-animation').forEach(btn => {
                setInterval(() => {
                    btn.classList.toggle('glow-effect');
                }, 2000);
            });
        });

        // Add some CSS for smooth transitions
        const style = document.createElement('style');
        style.textContent = `
            .movie-item {
                transition: all 0.3s ease-in-out;
            }
            .filter-btn {
                transition: all 0.3s ease;
            }
            .filter-btn.active {
                transform: translateY(-2px);
                box-shadow: 0 4px 8px rgba(0,0,0,0.2);
            }
            .badge.bg-outline-light {
                background: transparent;
                border: 1px solid #fff;
                color: #fff;
                cursor: pointer;
                transition: all 0.3s ease;
            }
            .badge.bg-outline-light:hover {
                background: rgba(255,255,255,0.1);
            }
        `;
        document.head.appendChild(style);
    </script>
}