@model List<ABCRMALLWebsite.Models.Movie>
@{
    ViewData["Title"] = "Manage Movies";
}
<div>
    <br>
</div>
<div>
    <br>
</div>
<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Manage Movies</h2>
        <div>
            <a href="@Url.Action("Dashboard")" class="btn btn-secondary">Back to Dashboard</a>
            <a href="@Url.Action("AddMovie")" class="btn btn-success">Add New Movie</a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }

    <div class="card shadow">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>ID</th>
                            <th>Movie</th>
                            <th>Genre</th>
                            <th>Duration</th>
                            <th>Seats</th>
                            <th>Price</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var movie in Model)
                        {
                            <tr>
                                <td>@movie.Id</td>
                                <td>
                                    <strong>@movie.Title</strong>
                                    @if (!string.IsNullOrEmpty(movie.ShowTimings))
                                    {
                                        <br>
                                
                                        <small class="text-muted">Timings: @movie.ShowTimings</small>
                                    }
                                </td>
                                <td>@movie.Genre</td>
                                <td>@movie.Duration</td>
                                <td>
                                    <span class="badge bg-success">@movie.AvailableSeats Available</span><br>
                                    <small>Total: @movie.TotalSeats</small>
                                </td>
                                <td>$@movie.TicketPrice</td>
                                <td>
                                    <div class="btn-group btn-group-sm">
                                        <a href="@Url.Action("EditMovie", new { id = movie.Id })"
                                           class="btn btn-warning">Edit</a>
                                        <a href="@Url.Action("DeleteMovie", new { id = movie.Id })"
                                           class="btn btn-danger"
                                           onclick="return confirm('Are you sure you want to delete this movie?')">Delete</a>
                                    </div>
                                </td>
                            </tr>
                        }

                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="7" class="text-center text-muted py-4">
                                    <h5>No movies found</h5>
                                    <p>Add your first movie to get started!</p>
                                    <a href="@Url.Action("AddMovie")" class="btn btn-primary">Add First Movie</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>