@model List<ABCRMALLWebsite.Models.TicketBooking>
@{
    ViewData["Title"] = "My Bookings - ABC Mall";
}

<!-- Hero Section -->
<section class="hero-section text-white py-5 mt-5" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-8" data-aos="fade-right">
                <h1 class="display-4 fw-bold mb-3">📋 My Bookings</h1>
                <p class="lead mb-4">View and manage all your movie bookings in one place</p>
            </div>
            <div class="col-lg-4 text-center" data-aos="fade-left">
                <div class="floating-card glass-effect p-4 rounded-3">
                    <i class="fas fa-clipboard-list fa-5x text-white mb-3"></i>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Search Section -->
<section class="py-5 bg-light">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card floating-card border-0 shadow-sm">
                    <div class="card-body p-4">
                        <h5 class="card-title mb-4">
                            <i class="fas fa-search me-2"></i>Find Your Bookings
                        </h5>
                        <form method="get" class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Email Address</label>
                                <input type="email" name="email" class="form-control"
                                       value="@ViewBag.SearchEmail" placeholder="your@email.com">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Phone Number</label>
                                <input type="tel" name="phone" class="form-control"
                                       value="@ViewBag.SearchPhone" placeholder="+91 XXXXX XXXXX">
                            </div>
                            <div class="col-12 text-center">
                                <button type="submit" class="btn btn-primary px-5">
                                    <i class="fas fa-search me-2"></i>Search Bookings
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Bookings List -->
<section class="py-5">
    <div class="container">
        @if (Model.Any())
        {
            <div class="row">
                <div class="col-12">
                    <h3 class="text-center mb-5">Your Booking History</h3>

                    @foreach (var booking in Model)
                    {
                        <div class="card floating-card border-0 shadow-sm mb-4" data-aos="fade-up">
                            <div class="card-body">
                                <div class="row align-items-center">
                                    <div class="col-md-8">
                                        <div class="row">
                                            <div class="col-sm-6 mb-2">
                                                <strong>Movie:</strong> @booking.Movie?.Title
                                            </div>
                                            <div class="col-sm-6 mb-2">
                                                <strong>Show Time:</strong> @booking.ShowTime.ToString("MMM dd, yyyy hh:mm tt")
                                            </div>
                                            <div class="col-sm-6 mb-2">
                                                <strong>Tickets:</strong> <span class="badge bg-primary">@booking.NumberOfTickets</span>
                                            </div>
                                            <div class="col-sm-6 mb-2">
                                                <strong>Amount:</strong> <span class="text-success fw-bold">₹@booking.TotalAmount</span>
                                            </div>
                                            <div class="col-sm-6 mb-2">
                                                <strong>Booked On:</strong> @booking.BookingDate.ToString("MMM dd, yyyy")
                                            </div>
                                            <div class="col-sm-6 mb-2">
                                                <strong>Status:</strong>
                                                <span class="badge @(booking.BookingStatus == "Confirmed" ? "bg-success" : "bg-secondary")">
                                                    @booking.BookingStatus
                                                </span>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4 text-center">
                                        <div class="booking-actions">
                                            @if (booking.BookingStatus == "Confirmed" && booking.ShowTime > DateTime.Now.AddHours(2))
                                            {
                                                <button class="btn btn-outline-danger btn-sm mb-2 cancel-btn"
                                                        data-booking-id="@booking.Id">
                                                    <i class="fas fa-times me-1"></i>Cancel
                                                </button>
                                            }
                                            <div class="booking-id">
                                                <small class="text-muted">Booking #@booking.Id</small>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
        else if (!string.IsNullOrEmpty(ViewBag.SearchEmail) || !string.IsNullOrEmpty(ViewBag.SearchPhone))
        {
            <div class="row justify-content-center">
                <div class="col-lg-6 text-center" data-aos="fade-up">
                    <div class="empty-state">
                        <i class="fas fa-ticket-alt fa-4x text-muted mb-3"></i>
                        <h3 class="text-muted">No Bookings Found</h3>
                        <p class="text-muted">We couldn't find any bookings matching your search criteria.</p>
                        <a href="@Url.Action("Movies", "Home")" class="btn btn-primary">
                            <i class="fas fa-film me-2"></i>Book Tickets Now
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</section>

@section Scripts {
    <script>
        // Cancel booking functionality
        document.querySelectorAll('.cancel-btn').forEach(button => {
            button.addEventListener('click', function() {
                const bookingId = this.getAttribute('data-booking-id');

                if (confirm('Are you sure you want to cancel this booking?')) {
                    fetch('@Url.Action("CancelBooking", "Booking")', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                        },
                        body: JSON.stringify({ bookingId: parseInt(bookingId) })
                    })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            alert(data.message);
                            location.reload();
                        } else {
                            alert(data.message);
                        }
                    })
                    .catch(error => {
                        console.error('Error:', error);
                        alert('An error occurred while cancelling the booking.');
                    });
                }
            });
        });

        // Add search validation
        document.querySelector('form').addEventListener('submit', function(e) {
            const email = document.querySelector('input[name="email"]').value;
            const phone = document.querySelector('input[name="phone"]').value;

            if (!email && !phone) {
                e.preventDefault();
                alert('Please enter either email or phone number to search bookings.');
            }
        });
    </script>
}