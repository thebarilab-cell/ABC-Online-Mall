@model List<ABCRMALLWebsite.Models.Shop>
@{
    ViewData["Title"] = "Shopping ABC Mall - Premier Shopping Destination";
}

<!-- Hero Section -->
<section class="hero-section text-white py-5 mt-5" style="background: var(--secondary-gradient);">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-8" data-aos="fade-right">
                <h1 class="display-3 fw-bold mb-4">🛍️ Shopping Experience</h1>
                <p class="lead mb-4">Discover 200+ premium brands across fashion, electronics, lifestyle, and more. Your perfect shopping destination awaits!</p>
                <div class="search-box">
                    <div class="input-group input-group-lg">
                        <input type="text" class="form-control" placeholder="Search brands, products...">
                        <button class="btn btn-light" type="button">
                            <i class="fas fa-search"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Categories Filter -->
<section class="py-4 bg-light">
    <div class="container">
        <div class="row">
            <div class="col-12">
                <div class="d-flex flex-wrap justify-content-center gap-3">
                    <button class="btn btn-outline-primary active filter-btn" data-filter="all">All Categories</button>
                    <button class="btn btn-outline-primary filter-btn" data-filter="Fashion">👗 Fashion</button>
                    <button class="btn btn-outline-primary filter-btn" data-filter="Electronics">📱 Electronics</button>
                    <button class="btn btn-outline-primary filter-btn" data-filter="Sports">⚽ Sports</button>
                    <button class="btn btn-outline-primary filter-btn" data-filter="Beauty">💄 Beauty</button>
                    <button class="btn btn-outline-primary filter-btn" data-filter="Home">🏠 Home</button>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Shops Grid -->
<section class="py-5">
    <div class="container">
        <div class="row" id="shops-container">
            @foreach (var shop in Model)
            {
                <div class="col-xl-3 col-lg-4 col-md-6 mb-4 shop-item" data-category="@shop.Category">
                    <div class="card floating-card hover-3d border-0 h-100" data-aos="zoom-in">
                        <div class="position-relative overflow-hidden">
                            <img src="@(string.IsNullOrEmpty(shop.ImagePath) ? "https://images.unsplash.com/photo-1441986300917-64674bd600d8?ixlib=rb-4.0.3&auto=format&fit=crop&w=500&q=80" : shop.ImagePath)"
                                 class="card-img-top" alt="@shop.Name" style="height: 200px; object-fit: cover;">
                            <div class="position-absolute top-0 end-0 m-3">
                                <span class="badge bg-primary">@shop.Floor</span>
                            </div>
                        </div>
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title fw-bold">@shop.Name</h5>
                            <span class="badge bg-light text-dark mb-2 align-self-start">@shop.Category</span>
                            <p class="card-text flex-grow-1 text-muted">@shop.Description</p>
                            <div class="mt-auto">
                                <div class="d-flex justify-content-between align-items-center">
                                    <small class="text-muted">Featured Items:</small>
                                </div>
                                <p class="small text-primary">@shop.ItemsList</p>
                            </div>
                        </div>
                    </div>
                </div>
            }

            @if (!Model.Any())
            {
                <div class="col-12 text-center py-5" data-aos="fade-up">
                    <div class="empty-state">
                        <i class="fas fa-store fa-4x text-muted mb-3"></i>
                        <h3 class="text-muted">No shops available</h3>
                        <p class="text-muted">New stores coming soon!</p>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

@section Scripts {
    <script>
        // Filter functionality
        document.querySelectorAll('.filter-btn').forEach(button => {
            button.addEventListener('click', function() {
                // Remove active class from all buttons
                document.querySelectorAll('.filter-btn').forEach(btn => btn.classList.remove('active'));
                // Add active class to clicked button
                this.classList.add('active');

                const filter = this.getAttribute('data-filter');
                const items = document.querySelectorAll('.shop-item');

                items.forEach(item => {
                    if (filter === 'all' || item.getAttribute('data-category') === filter) {
                        item.style.display = 'block';
                    } else {
                        item.style.display = 'none';
                    }
                });
            });
        });

        // Add hover effects with GSAP
        document.querySelectorAll('.floating-card').forEach(card => {
            card.addEventListener('mouseenter', () => {
                gsap.to(card, { duration: 0.3, y: -10, ease: "power2.out" });
            });

            card.addEventListener('mouseleave', () => {
                gsap.to(card, { duration: 0.3, y: 0, ease: "power2.out" });
            });
        });
    </script>
}