@model List<ABCRMALLWebsite.Models.Gallery>
@{
    ViewData["Title"] = "Gallery ABC Mall - Premier Shopping Destination";
}

<!-- Hero Section -->
<section class="hero-section text-white py-5 mt-5" style="background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-8" data-aos="fade-right">
                <h1 class="display-3 fw-bold mb-4">📸 Our Gallery</h1>
                <p class="lead mb-4">Step into the vibrant world of ABC Mall through stunning visuals of our spaces, events, and experiences.</p>
                <div class="d-flex flex-wrap gap-3">
                    <a href="#gallery-grid" class="btn btn-light btn-lg px-4 py-2">
                        <i class="fas fa-images me-2"></i>View Gallery
                    </a>
                </div>
            </div>
            <div class="col-lg-4" data-aos="fade-left">
                <div class="text-center">
                    <div class="floating-card glass-effect p-4 rounded-3">
                        <i class="fas fa-camera fa-6x text-white mb-3"></i>
                        <h4 class="text-white">Visual Journey</h4>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Gallery Filters -->
<section class="py-4 bg-light">
    <div class="container">
        <div class="row">
            <div class="col-12">
                <div class="d-flex flex-wrap justify-content-center gap-3">
                    <button class="btn btn-outline-info active filter-btn" data-filter="all">All Photos</button>
                    <button class="btn btn-outline-info filter-btn" data-filter="Shops">🛍️ Shops</button>
                    <button class="btn btn-outline-info filter-btn" data-filter="Food">🍔 Food</button>
                    <button class="btn btn-outline-info filter-btn" data-filter="Events">🎉 Events</button>
                    <button class="btn btn-outline-info filter-btn" data-filter="Infrastructure">🏢 Infrastructure</button>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Gallery Grid -->
<section id="gallery-grid" class="py-5">
    <div class="container">
        <div class="row g-3" id="gallery-container">
            @foreach (var image in Model)
            {
                <div class="col-xl-3 col-lg-4 col-md-6 gallery-item" data-category="@image.Category" data-aos="zoom-in">
                    <div class="card floating-card hover-3d border-0 overflow-hidden">
                        <img src="@image.ImagePath" class="card-img-top gallery-image" alt="@image.Title"
                             style="height: 250px; object-fit: cover; cursor: pointer;"
                             data-bs-toggle="modal" data-bs-target="#imageModal"
                             data-image="@image.ImagePath"
                             data-title="@image.Title"
                             data-description="@image.Description">
                        <div class="card-body">
                            <h6 class="card-title fw-bold">@image.Title</h6>
                            <p class="card-text small text-muted">@image.Description</p>
                            <span class="badge bg-info">@image.Category</span>
                        </div>
                    </div>
                </div>
            }

            @if (!Model.Any())
            {
                <div class="col-12 text-center py-5" data-aos="fade-up">
                    <div class="empty-state">
                        <i class="fas fa-images fa-4x text-muted mb-3"></i>
                        <h3 class="text-muted">Gallery Coming Soon!</h3>
                        <p class="text-muted">We're capturing amazing moments for you!</p>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- Image Modal -->
<div class="modal fade" id="imageModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header glass-effect">
                <h5 class="modal-title" id="modalTitle"></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center p-0">
                <img id="modalImage" src="" class="img-fluid w-100" style="max-height: 70vh; object-fit: contain;" alt="">
            </div>
            <div class="modal-footer glass-effect">
                <p id="modalDescription" class="text-muted mb-0"></p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Gallery filter
        document.querySelectorAll('.filter-btn').forEach(button => {
            button.addEventListener('click', function() {
                document.querySelectorAll('.filter-btn').forEach(btn => btn.classList.remove('active'));
                this.classList.add('active');

                const filter = this.getAttribute('data-filter');
                const items = document.querySelectorAll('.gallery-item');

                items.forEach(item => {
                    if (filter === 'all' || item.getAttribute('data-category') === filter) {
                        item.style.display = 'block';
                        setTimeout(() => {
                            item.style.opacity = '1';
                        }, 50);
                    } else {
                        item.style.opacity = '0';
                        setTimeout(() => {
                            item.style.display = 'none';
                        }, 300);
                    }
                });
            });
        });

        // Modal functionality
        const imageModal = document.getElementById('imageModal');
        imageModal.addEventListener('show.bs.modal', function(event) {
            const button = event.relatedTarget;
            const imageSrc = button.getAttribute('data-image');
            const title = button.getAttribute('data-title');
            const description = button.getAttribute('data-description');

            document.getElementById('modalImage').src = imageSrc;
            document.getElementById('modalTitle').textContent = title;
            document.getElementById('modalDescription').textContent = description;
        });

        // Masonry-like layout
        function layoutGallery() {
            const container = document.getElementById('gallery-container');
            const items = container.getElementsByClassName('gallery-item');

            // Simple masonry effect
            let maxHeight = 0;
            Array.from(items).forEach(item => {
                const height = item.offsetHeight;
                if (height > maxHeight) maxHeight = height;
            });
        }

        // Initialize on load
        window.addEventListener('load', layoutGallery);
        window.addEventListener('resize', layoutGallery);

        // Add parallax effect to gallery images
        document.querySelectorAll('.gallery-image').forEach(img => {
            img.addEventListener('mousemove', (e) => {
                const x = e.clientX / window.innerWidth;
                const y = e.clientY / window.innerHeight;

                img.style.transform = `scale(1.05) rotateX(${y * 10}deg) rotateY(${x * 10}deg)`;
            });

            img.addEventListener('mouseleave', () => {
                img.style.transform = 'scale(1) rotateX(0) rotateY(0)';
            });
        });
    </script>
}